{
  "name": "bise-frontend",
  "description": "Frontend server for BISE",
  "license": "MIT",
  "version": "3.2.7",
  "private": "true",
  "workspaces": [
    "src/develop/volto-base",
    "src/develop/volto-addons",
    "src/develop/volto-base",
    "src/develop/volto-blocks",
    "src/develop/volto-ckeditor",
    "src/develop/volto-datablocks",
    "src/develop/volto-drafteditor",
    "src/develop/volto-embed",
    "src/develop/volto-mosaic",
    "src/develop/volto-plotlycharts",
    "src/develop/volto-sidebar"
  ],
  "scripts": {
    "develop:npx": "npx -p mrs-developer missdev --config=jsconfig.json --output=develop",
    "develop": "missdev --config=jsconfig.json --output=develop",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 razzle start",
    "start:prod": "NODE_ENV=production node build/server.js",
    "build": "razzle build",
    "i18n": "NODE_ENV=production node node_modules/@plone/volto/src/i18n.js",
    "test": "razzle test --env=jsdom --passWithNoTests",
    "analyze": "webpack-bundle-analyzer -p $PORT -h 0.0.0.0 ./build/public/stats.json",
    "omelette": "ln -sf node_modules/@plone/volto/ omelette",
    "serve": "http-server -p $PORT ./build"
  },
  "jest": {
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "transform": {
      "^.+\\.js(x)?$": "babel-jest",
      "^.+\\.css$": "jest-css-modules",
      "^.+\\.scss$": "jest-css-modules",
      "^.+\\.(png)$": "jest-file",
      "^.+\\.(jpg)$": "jest-file",
      "^.+\\.(svg)$": "./node_modules/@plone/volto/jest-svgsystem-transform.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!@plone/volto).+\\.js$"
    ],
    "moduleNameMapper": {
      "@plone/volto/(.*)$": "<rootDir>/node_modules/@plone/volto/src/$1",
      "@package/(.*)$": "<rootDir>/src/$1",
      "~/(.*)$": "<rootDir>/src/$1"
    },
    "coverageThreshold": {
      "global": {
        "branches": 10,
        "functions": 10,
        "lines": 10,
        "statements": 10
      }
    },
    "setupFiles": [
      "@plone/volto/test-setup.js"
    ],
    "globals": {
      "__DEV__": true
    }
  },
  "customizationPaths": [
    "src/customizations/volto/"
  ],
  "addonsCustomizationPath": "src/customizations",
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-idiomatic-order",
      "./node_modules/prettier-stylelint/config.js"
    ]
  },
  "engines": {
    "node": "^8 || ^10"
  },
  "bundlesize": [
    {
      "path": "build/public/static/js/*.js",
      "maxSize": "680kB"
    }
  ],
  "bundlewatch": {
    "files": [
      {
        "path": "build/public/static/js/*.js",
        "maxSize": "680kB"
      }
    ]
  },
  "browserslist": [
    ">1%",
    "last 4 versions",
    "Firefox ESR",
    "not ie < 9"
  ],
  "resolutions": {
    "browserslist": "4.8.3"
  },
  "dependencies": {
    "@babel/core": "7.9.6",
